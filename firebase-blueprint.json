{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with institution settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "schoolName": { "type": "string" },
        "academyName": { "type": "string" },
        "provincialName": { "type": "string" },
        "currentCity": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Student": {
      "title": "Student",
      "description": "Student record for transfers",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID who owns this record" },
        "studentNum": { "type": "string" },
        "lastName": { "type": "string" },
        "firstName": { "type": "string" },
        "transferDate": { "type": "string" },
        "transferType": { "type": "string" },
        "receivingInst": { "type": "string" },
        "originalInst": { "type": "string" },
        "originalDir": { "type": "string" },
        "level": { "type": "string" },
        "requestDate1": { "type": "string" },
        "requestDate2": { "type": "string" },
        "requestDate3": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "studentNum", "lastName", "firstName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User institution settings"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student records for the application"
    }
  }
}
