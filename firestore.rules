rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - schoolName: string
    //   - academyName: string
    //   - provincialName: string
    //   - currentCity: string
    //
    // Collection: students
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, owner ID)
    //   - studentNum: string (required)
    //   - lastName: string (required)
    //   - firstName: string (required)
    //   - transferDate: string
    //   - transferType: string
    //   - receivingInst: string
    //   - originalInst: string
    //   - originalDir: string
    //   - level: string
    //   - createdAt: string
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['uid', 'studentNum', 'lastName', 'firstName']) &&
             data.uid == request.auth.uid &&
             data.studentNum is string && data.studentNum.size() < 100 &&
             data.lastName is string && data.lastName.size() < 100 &&
             data.firstName is string && data.firstName.size() < 100;
    }

    // Role-based Access (Optional, default to owner-only)
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /students/{studentId} {
      // Users can only read their own students
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      
      allow create: if isAuthenticated() && isValidStudent(request.resource.data);
      
      allow update: if isDocOwner() && isValidStudent(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid; // uid must remain same
                      
      allow delete: if isDocOwner();
    }
  }
}
